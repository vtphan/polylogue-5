generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// --- User entities ---

model Researcher {
  id           String   @id @default(uuid())
  username     String   @unique
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")

  teachers  Teacher[]
  scenarios Scenario[]

  @@map("researchers")
}

model Teacher {
  id           String   @id @default(uuid())
  fullName     String   @map("full_name")
  username     String   @unique
  passwordHash String   @map("password_hash")
  createdById  String   @map("created_by")
  createdAt    DateTime @default(now()) @map("created_at")

  createdBy Researcher @relation(fields: [createdById], references: [id])
  classes   Class[]
  sessions  Session[]

  @@map("teachers")
}

model Student {
  id            String   @id @default(uuid())
  fullName      String   @map("full_name")
  createdByRole String   @map("created_by_role") // "researcher" | "teacher"
  createdById   String   @map("created_by_id")
  createdAt     DateTime @default(now()) @map("created_at")

  classEnrollments       ClassEnrollment[]
  groupMemberships       GroupMembership[]
  sessionGroupMemberships SessionGroupMembership[]
  lensAssignments        LensAssignment[]
  evaluateResponses      EvaluateResponse[]
  explainResponses       ExplainResponse[]
  submittedConsensus     GroupConsensus[]

  @@map("students")
}

// --- Class entities ---

model Class {
  id        String   @id @default(uuid())
  name      String
  section   String?
  teacherId String   @map("teacher_id")
  createdAt DateTime @default(now()) @map("created_at")

  teacher     Teacher           @relation(fields: [teacherId], references: [id])
  enrollments ClassEnrollment[]
  groups      Group[]
  sessions    Session[]

  @@map("classes")
}

model ClassEnrollment {
  studentId  String   @map("student_id")
  classId    String   @map("class_id")
  enrolledAt DateTime @default(now()) @map("enrolled_at")

  student Student @relation(fields: [studentId], references: [id])
  class   Class   @relation(fields: [classId], references: [id])

  @@id([studentId, classId])
  @@map("class_enrollments")
}

model Group {
  id        String   @id @default(uuid())
  classId   String   @map("class_id")
  label     String
  createdAt DateTime @default(now()) @map("created_at")

  class       Class             @relation(fields: [classId], references: [id])
  memberships GroupMembership[]

  @@map("groups")
}

model GroupMembership {
  studentId String @map("student_id")
  groupId   String @map("group_id")

  student Student @relation(fields: [studentId], references: [id])
  group   Group   @relation(fields: [groupId], references: [id])

  @@id([studentId, groupId])
  @@map("group_memberships")
}

// --- Scenario ---

model Scenario {
  id          String   @id // text ID from pipeline, not auto-generated
  status      String   @default("available") // "available" | "hidden"
  publishedBy String   @map("published_by")
  topic       String
  artifacts   String   // JSON string (SQLite has no native jsonb)
  publishedAt DateTime @default(now()) @map("published_at")

  publisher Researcher @relation(fields: [publishedBy], references: [id])
  sessions  Session[]

  @@map("scenarios")
}

// --- Session entities ---

model Session {
  id                          String    @id @default(uuid())
  classId                     String    @map("class_id")
  scenarioId                  String    @map("scenario_id")
  createdById                 String    @map("created_by")
  status                      String    @default("draft") // "draft" | "active" | "closed"
  joinCode                    String?   @unique @map("join_code")
  lensAssignmentMode          String    @default("assign") @map("lens_assignment_mode") // "assign" | "choice"
  selectedPassages            String?   @map("selected_passages") // JSON array of passage IDs
  scaffoldingSentenceStarters Boolean   @default(true) @map("scaffolding_sentence_starters")
  scaffoldingReferenceLists   Boolean   @default(true) @map("scaffolding_reference_lists")
  thresholdEvaluate           Int?      @map("threshold_evaluate")
  thresholdExplain            Int?      @map("threshold_explain")
  createdAt                   DateTime  @default(now()) @map("created_at")
  updatedAt                   DateTime  @updatedAt @map("updated_at")
  activatedAt                 DateTime? @map("activated_at")
  closedAt                    DateTime? @map("closed_at")

  class             Class              @relation(fields: [classId], references: [id])
  scenario          Scenario           @relation(fields: [scenarioId], references: [id])
  createdBy         Teacher            @relation(fields: [createdById], references: [id])
  sessionGroups     SessionGroup[]
  lensAssignments   LensAssignment[]
  evaluateResponses EvaluateResponse[]
  explainResponses  ExplainResponse[]
  groupConsensus    GroupConsensus[]

  @@map("sessions")
}

model SessionGroup {
  id        String @id @default(uuid())
  sessionId String @map("session_id")
  label     String

  session    Session                  @relation(fields: [sessionId], references: [id])
  memberships SessionGroupMembership[]
  consensus  GroupConsensus[]

  @@map("session_groups")
}

model SessionGroupMembership {
  sessionGroupId String @map("session_group_id")
  studentId      String @map("student_id")

  sessionGroup SessionGroup @relation(fields: [sessionGroupId], references: [id])
  student      Student      @relation(fields: [studentId], references: [id])

  @@id([sessionGroupId, studentId])
  @@map("session_group_memberships")
}

model LensAssignment {
  sessionId  String   @map("session_id")
  studentId  String   @map("student_id")
  lensId     String   @map("lens_id") // "logic" | "evidence" | "scope"
  assignedAt DateTime @default(now()) @map("assigned_at")

  session Session @relation(fields: [sessionId], references: [id])
  student Student @relation(fields: [studentId], references: [id])

  @@id([sessionId, studentId])
  @@map("lens_assignments")
}

// --- Response entities (append-only) ---

model EvaluateResponse {
  id                String   @id @default(uuid())
  sessionId         String   @map("session_id")
  studentId         String   @map("student_id")
  passageId         String   @map("passage_id")
  step              String   // "individual" | "peer" | "ai"
  lensId            String   @map("lens_id") // "logic" | "evidence" | "scope"
  rating            String?  // "strong" | "weak" — individual step only
  content           String
  hintUsed          Boolean? @map("hint_used") // individual step only
  redirectTriggered Boolean? @map("redirect_triggered") // individual step only
  createdAt         DateTime @default(now()) @map("created_at")

  session Session @relation(fields: [sessionId], references: [id])
  student Student @relation(fields: [studentId], references: [id])

  @@map("evaluate_responses")
}

model ExplainResponse {
  id        String   @id @default(uuid())
  sessionId String   @map("session_id")
  studentId String   @map("student_id")
  passageId String   @map("passage_id")
  step      String   // "individual" | "peer" | "ai"
  content   String
  hintUsed  Boolean? @map("hint_used") // individual step only
  createdAt DateTime @default(now()) @map("created_at")

  session Session @relation(fields: [sessionId], references: [id])
  student Student @relation(fields: [studentId], references: [id])

  @@map("explain_responses")
}

// --- Group consensus ---

model GroupConsensus {
  id             String   @id @default(uuid())
  sessionId      String   @map("session_id")
  sessionGroupId String   @map("session_group_id")
  passageId      String   @map("passage_id")
  phase          String   // "evaluate" | "explain"
  position       String   // "agree" | "disagree"
  rationale      String
  submittedBy    String   @map("submitted_by")
  createdAt      DateTime @default(now()) @map("created_at")

  session      Session      @relation(fields: [sessionId], references: [id])
  sessionGroup SessionGroup @relation(fields: [sessionGroupId], references: [id])
  submitter    Student      @relation(fields: [submittedBy], references: [id])

  @@unique([sessionId, sessionGroupId, passageId, phase])
  @@map("group_consensus")
}
