generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// --- Enums ---

enum CreatedByRole {
  researcher
  teacher
}

enum ScenarioStatus {
  available
  hidden
}

enum SessionStatus {
  draft
  active
  closed
}

enum LensTag {
  evidence
  logic
  scope
}

enum CategoryTag {
  cognitive
  social
  interaction
}

enum Phase {
  evaluate
  explain
}

// --- User entities ---

model Researcher {
  id           String   @id @default(uuid())
  username     String   @unique
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")

  teachers  Teacher[]
  scenarios Scenario[]

  @@map("researchers")
}

model Teacher {
  id           String   @id @default(uuid())
  fullName     String   @map("full_name")
  username     String   @unique
  passwordHash String   @map("password_hash")
  createdById  String   @map("created_by")
  createdAt    DateTime @default(now()) @map("created_at")

  createdBy   Researcher  @relation(fields: [createdById], references: [id])
  classes     Class[]
  sessions    Session[]
  growthNotes GrowthNote[]

  @@map("teachers")
}

model Student {
  id            String        @id @default(uuid())
  fullName      String        @map("full_name")
  createdByRole CreatedByRole @map("created_by_role")
  createdById   String        @map("created_by_id")
  createdAt     DateTime      @default(now()) @map("created_at")

  classEnrollments        ClassEnrollment[]
  groupMemberships        GroupMembership[]
  sessionGroupMemberships SessionGroupMembership[]
  evaluateResponses       EvaluateResponse[]
  explainResponses        ExplainResponse[]
  submittedDiagnoses      GroupDiagnosis[]
  growthNotes             GrowthNote[]

  @@map("students")
}

model GrowthNote {
  id        String   @id @default(uuid())
  studentId String   @map("student_id")
  teacherId String   @map("teacher_id")
  content   String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  student Student @relation(fields: [studentId], references: [id])
  teacher Teacher @relation(fields: [teacherId], references: [id])

  @@unique([studentId, teacherId])
  @@map("growth_notes")
}

// --- Class entities ---

model Class {
  id        String   @id @default(uuid())
  name      String
  section   String?
  teacherId String   @map("teacher_id")
  createdAt DateTime @default(now()) @map("created_at")

  teacher     Teacher           @relation(fields: [teacherId], references: [id])
  enrollments ClassEnrollment[]
  groups      Group[]
  sessions    Session[]

  @@map("classes")
}

model ClassEnrollment {
  studentId  String   @map("student_id")
  classId    String   @map("class_id")
  enrolledAt DateTime @default(now()) @map("enrolled_at")

  student Student @relation(fields: [studentId], references: [id])
  class   Class   @relation(fields: [classId], references: [id])

  @@id([studentId, classId])
  @@map("class_enrollments")
}

model Group {
  id        String   @id @default(uuid())
  classId   String   @map("class_id")
  label     String
  createdAt DateTime @default(now()) @map("created_at")

  class       Class             @relation(fields: [classId], references: [id])
  memberships GroupMembership[]

  @@map("groups")
}

model GroupMembership {
  studentId String @map("student_id")
  groupId   String @map("group_id")

  student Student @relation(fields: [studentId], references: [id])
  group   Group   @relation(fields: [groupId], references: [id])

  @@id([studentId, groupId])
  @@map("group_memberships")
}

// --- Scenario ---

model Scenario {
  id          String         @id // text ID from pipeline, not auto-generated
  status      ScenarioStatus @default(available)
  publishedBy String         @map("published_by")
  topic       String
  artifacts   String         // JSON string (SQLite has no native jsonb)
  publishedAt DateTime       @default(now()) @map("published_at")

  publisher Researcher @relation(fields: [publishedBy], references: [id])
  sessions  Session[]

  @@map("scenarios")
}

// --- Session entities ---

model Session {
  id                          String        @id @default(uuid())
  classId                     String        @map("class_id")
  scenarioId                  String        @map("scenario_id")
  createdById                 String        @map("created_by")
  status                      SessionStatus @default(draft)
  joinCode                    String?       @unique @map("join_code")
  selectedPassages            String?       @map("selected_passages") // JSON array of passage IDs
  scaffoldingSentenceStarters Boolean       @default(true) @map("scaffolding_sentence_starters")
  scaffoldingReferenceLists   Boolean       @default(true) @map("scaffolding_reference_lists")
  lifelinesPerPhase           Int?          @map("lifelines_per_phase") // null = default (1 per passage)
  createdAt                   DateTime      @default(now()) @map("created_at")
  updatedAt                   DateTime      @updatedAt @map("updated_at")
  activatedAt                 DateTime?     @map("activated_at")
  closedAt                    DateTime?     @map("closed_at")

  class             Class              @relation(fields: [classId], references: [id])
  scenario          Scenario           @relation(fields: [scenarioId], references: [id])
  createdBy         Teacher            @relation(fields: [createdById], references: [id])
  sessionGroups     SessionGroup[]
  evaluateResponses EvaluateResponse[]
  explainResponses  ExplainResponse[]
  groupDiagnoses    GroupDiagnosis[]
  lifelineUsages    LifelineUsage[]

  @@map("sessions")
}

model SessionGroup {
  id        String @id @default(uuid())
  sessionId String @map("session_id")
  label     String

  session     Session                  @relation(fields: [sessionId], references: [id])
  memberships SessionGroupMembership[]
  diagnoses   GroupDiagnosis[]
  lifelines   LifelineUsage[]

  @@map("session_groups")
}

model SessionGroupMembership {
  sessionGroupId String @map("session_group_id")
  studentId      String @map("student_id")

  sessionGroup SessionGroup @relation(fields: [sessionGroupId], references: [id])
  student      Student      @relation(fields: [studentId], references: [id])

  @@id([sessionGroupId, studentId])
  @@map("session_group_memberships")
}

// --- Individual responses (append-only) ---

model EvaluateResponse {
  id                String   @id @default(uuid())
  clientId          String?  @unique @map("client_id")
  sessionId         String   @map("session_id")
  studentId         String   @map("student_id")
  passageId         String   @map("passage_id")
  content           String   // free-form diagnosis text
  lensTag           LensTag  @map("lens_tag") // which kind of problem they noticed
  redirectTriggered Boolean  @default(false) @map("redirect_triggered")
  redirectContent   String?  @map("redirect_content") // extended thinking after misreading redirect
  isAppend          Boolean  @default(false) @map("is_append") // true if added after seeing peers
  createdAt         DateTime @default(now()) @map("created_at")

  session Session @relation(fields: [sessionId], references: [id])
  student Student @relation(fields: [studentId], references: [id])

  @@map("evaluate_responses")
}

model ExplainResponse {
  id          String      @id @default(uuid())
  clientId    String?     @unique @map("client_id")
  sessionId   String      @map("session_id")
  studentId   String      @map("student_id")
  passageId   String      @map("passage_id")
  content     String      // free-form explanation text
  categoryTag CategoryTag @map("category_tag") // cognitive, social, or interaction
  isAppend    Boolean     @default(false) @map("is_append")
  createdAt   DateTime    @default(now()) @map("created_at")

  session Session @relation(fields: [sessionId], references: [id])
  student Student @relation(fields: [studentId], references: [id])

  @@map("explain_responses")
}

// --- Group diagnosis ---

model GroupDiagnosis {
  id             String      @id @default(uuid())
  sessionId      String      @map("session_id")
  sessionGroupId String      @map("session_group_id")
  passageId      String      @map("passage_id")
  phase          Phase
  content        String      // group's best diagnosis/explanation
  lensTag        LensTag?    @map("lens_tag") // evaluate phase
  categoryTag    CategoryTag? @map("category_tag") // explain phase
  submittedBy    String      @map("submitted_by")
  createdAt      DateTime    @default(now()) @map("created_at")

  session      Session      @relation(fields: [sessionId], references: [id])
  sessionGroup SessionGroup @relation(fields: [sessionGroupId], references: [id])
  submitter    Student      @relation(fields: [submittedBy], references: [id])

  @@unique([sessionId, sessionGroupId, passageId, phase])
  @@map("group_diagnoses")
}

// --- Lifeline usage ---

model LifelineUsage {
  id             String   @id @default(uuid())
  sessionId      String   @map("session_id")
  sessionGroupId String   @map("session_group_id")
  passageId      String   @map("passage_id")
  phase          Phase
  hintText       String   @map("hint_text") // which hint was revealed
  usedBy         String   @map("used_by") // student who clicked
  createdAt      DateTime @default(now()) @map("created_at")

  session      Session      @relation(fields: [sessionId], references: [id])
  sessionGroup SessionGroup @relation(fields: [sessionGroupId], references: [id])

  @@map("lifeline_usages")
}
